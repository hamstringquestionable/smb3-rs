    {"name": "World 2 (Desert Land)", "cpu_addr": 0xA63B, "file_offset": 0x1864B, "columns": 32, "screens": 2},
    {"name": "World 3 (Water Land)",  "cpu_addr": 0xA75C, "file_offset": 0x1876C, "columns": 48, "screens": 3},
